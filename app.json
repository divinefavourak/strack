{
  "expo": {
    "name": "strack",
    "slug": "strack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "strack",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.akcodex.strack"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#16531F",
        "foregroundImage": "./assets/images/logo-mark.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.akcodex.strack"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo-mark.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#16531F",
          "dark": {
            "backgroundColor": "#16531F"
          }
        }
      ],
      [
        "expo-sensors",
        {
          "motionPermission": "Allow Strack to count your steps."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Strack to use the microphone for voice commands."
        }
      ],
      "expo-secure-store",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.634533255578-7fc8b0d5ft9suloa5q1rt566b6aqndn6"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "29f0f806-e175-4393-a5a2-8ff013f5f959"
      },
      "apiBaseUrl": "https://strack-api-zyaa.onrender.com/api/v1",
      "google": {
        "iosClientId": "634533255578-7fc8b0d5ft9suloa5q1rt566b6aqndn6.apps.googleusercontent.com",
        "androidClientId": "634533255578-gmorcatt2ljb2tlsoupr88275e00kfut.apps.googleusercontent.com",
        "webClientId": "634533255578-8n3legi8srislfnjflgvs3jutps7bdv5.apps.googleusercontent.com"
      }
    }
  }
}
